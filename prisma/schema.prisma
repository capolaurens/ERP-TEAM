// Esquema de datos del ERP interno de Navyx.
// Prisma 7 (generador nuevo "prisma-client"). La URL de la base de datos
// se configura en prisma.config.ts (CLI) y en lib/prisma.ts (runtime, via adapter-pg).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MARKETING
  SALES
  DESIGN
  CLIENT
}

enum Team {
  MARKETING
  SALES
  DESIGN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  COMMENTED
  FILE_UPLOADED
  DUE_CHANGED
  PHASE_CHANGED
}

enum ModelPhase {
  MESH
  TEXTURE
  DONE
}

enum RewardKind {
  GRADE
  DAYS
  OTHER
}

enum RedemptionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(MARKETING)
  team         Team?
  avatarUrl    String?
  avatarSeed   String?
  active       Boolean  @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks   Task[]    @relation("TaskAssignee")
  createdTasks    Task[]    @relation("TaskCreatedBy")
  createdProjects Project[] @relation("ProjectCreatedBy")
  comments        Comment[]
  attachments     Attachment[]
  activities      Activity[]
  timeEntries     TimeEntry[]
  workSessions    WorkSession[]
  clientProjects  Project[]    @relation("ClientProjects")
  pointsEntries   PointsEntry[]
  redemptions     Redemption[]

  @@index([role])
  @@index([team])
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  team          Team
  status        String   @default("active") // active | archived
  color         String?
  websiteUrl    String?
  logoUrl       String?
  driveFolderId String?
  createdById   String?
  createdBy     User?    @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks       Task[]
  activities  Activity[]
  clientUsers User[]     @relation("ClientProjects")

  @@index([team])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  order       Int        @default(0)
  team        Team
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?      @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  googleEventId String?
  referenceUrl String?
  category     String?
  driveUrl     String?

  // Pipeline de validación 3D (malla -> textura -> completada)
  phase               ModelPhase @default(MESH)
  changesRequested    Boolean    @default(false)
  meshApprovedAt      DateTime?
  meshApprovedById    String?
  textureApprovedAt   DateTime?
  textureApprovedById String?
  clientApprovedAt    DateTime?
  clientApprovedById  String?

  // Portal del cliente (2026-07): el CLIENTE marca malla/textura; el ADMIN
  // abre la pieza al cliente con showToClient (si está en false no le aparece).
  clientMeshAt        DateTime?
  clientTextureAt     DateTime?
  showToClient        Boolean    @default(false)

  // Pipeline por fases (2026-07-08): el CHICO de diseño ENVÍA la malla/textura
  // (distinto de la aprobación del admin). De estos + los *ApprovedAt/client*At
  // se derivan las columnas del tablero (Sin empezar / Malla terminada / Para
  // textura / Textura añadida).
  meshSubmittedAt     DateTime?
  textureSubmittedAt  DateTime?

  comments    Comment[]
  attachments Attachment[]
  activities  Activity[]
  timeEntries TimeEntry[]
  modelImages ModelImage[]

  @@index([team])
  @@index([status])
  @@index([assigneeId])
  @@index([projectId])
  @@index([dueDate])
  @@index([phase])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Attachment {
  id               String   @id @default(cuid())
  taskId           String
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName         String
  mimeType         String
  size             Int
  team             Team
  driveFileId      String
  driveUrl         String
  driveDownloadUrl String?
  uploadedById     String?
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([taskId])
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  taskId    String?
  task      Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  meta      Json?
  createdAt DateTime     @default(now())

  @@index([taskId])
  @@index([projectId])
  @@index([createdAt])
}

model TeamDriveFolder {
  team          Team     @id
  driveFolderId String
  label         String?
  updatedAt     DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TimeEntry {
  id          String    @id @default(cuid())
  taskId      String?
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int       @default(0)
  withAI      Boolean   @default(false)
  phase       ModelPhase?
  note        String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([taskId])
  @@index([endedAt])
}

model ModelImage {
  id           String     @id @default(cuid())
  taskId       String
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  phase        ModelPhase @default(MESH)
  kind         String     @default("progress") // progress | reference
  data         Bytes
  mimeType     String
  fileName     String
  uploadedById String?
  createdAt    DateTime   @default(now())

  @@index([taskId])
}

model Reward {
  id          String       @id @default(cuid())
  title       String
  description String?
  costPoints  Int
  kind        RewardKind   @default(OTHER)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  redemptions Redemption[]

  @@index([active])
}

model PointsEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points       Int // + ganados, - gastados
  reason       String
  redemptionId String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Redemption {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId    String?
  reward      Reward?          @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  rewardTitle String
  costPoints  Int
  status      RedemptionStatus @default(PENDING)
  note        String?
  createdAt   DateTime         @default(now())
  decidedAt   DateTime?
  decidedById String?

  @@index([userId])
  @@index([status])
}

model WorkSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  endedAt    DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([startedAt])
}

/// Revisión pública de la galería 3D de Northdeco: check + comentarios que deja
/// el cliente (sin login) desde /northdeco. Un review por modelo (file = GLB).
model NorthdecoReview {
  file      String   @id
  checked   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model NorthdecoComment {
  id        String   @id @default(cuid())
  file      String
  author    String?
  text      String
  createdAt DateTime @default(now())

  @@index([file])
}
